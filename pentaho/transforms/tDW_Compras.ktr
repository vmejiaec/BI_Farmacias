    <connection>Datamart</connection>
    <sql>SELECT
  id_compra
, numero_orden
, factura_distribuidor
, fecha_compra
, fecha_estimada_entrega
, fecha_vencimiento
, codigo_sucursal
, codigo_medicamento
, codigo_distribuidor
, numero_lote
, cantidad_comprada
, costo_unitario
, subtotal_bruto
, porcentaje_descuento
, valor_descuento
, valor_neto
, estado_recepcion
FROM stg.excel_compras
</sql>
